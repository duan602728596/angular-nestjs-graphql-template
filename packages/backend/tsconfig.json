{
  "compilerOptions": {
    "tsBuildInfoFile": "./.nest/cache/tsconfig.build.tsbuildinfo",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ESNext",
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "incremental": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "types": [
      "jest",
      "node",
      "supertest"
    ]
  },
  "exclude": [
    "jest.config.ts",
    "jest-e2e.config.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.jest.json"
    }
  ]
}
